# candle api 환경변수 예시. 복사해서 .env로 쓰고 실제 값을 채운다(.env는 git 무시).
#   cp apps/api/.env.example apps/api/.env

# Supabase 프로젝트 설정 > API 에서 확인.
#  - Project URL
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
#  - service_role 키(비밀!). 서버 전용 — 절대 프론트엔드에 노출 금지.
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY

# 선택: 서버 포트(기본 3000)
# PORT=3000

# 위 두 값이 없으면 인메모리 저장소로 동작한다(개발용, 재시작 시 데이터 휘발).
